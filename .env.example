# ── Anthropic ────────────────────────────────────────────────────────────────
# Get from https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your-api-key-here

# Model to use (haiku is fast and cheap for demos)
MODEL=claude-haiku-4-5-20251001

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Auth ──────────────────────────────────────────────────────────────────────
# Credentials for the demo login (share these with your client)
DEMO_USER=demo
DEMO_PASSWORD=changeme-before-sharing

# Secret used to sign session cookies — generate a random string
SESSION_SECRET=change-this-to-a-random-string
