# ── Anthropic ────────────────────────────────────────────────────────────────
# Get from https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your-api-key-here

# Model to use (haiku is fast and cheap for demos)
MODEL=claude-haiku-4-5-20251001

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Auth ──────────────────────────────────────────────────────────────────────
# Credentials for the demo login (share these with your client)
DEMO_USER=demo
DEMO_PASSWORD=changeme-before-sharing

# Secret used to sign session cookies — generate a random string
SESSION_SECRET=change-this-to-a-random-string

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — used locally and on Render with a Persistent Disk)
# On Render: set this to the disk mount path, e.g. /var/data/chatbot.db
# The render.yaml already sets this automatically if you use it.
DB_PATH=./chatbot.db

# Azure migration: when you're ready to move to Azure Database for PostgreSQL
# or Azure SQL, set DATABASE_URL here and update database.js to use an async
# driver (pg / mssql). The DB_PATH var can be removed at that point.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
